# ================================================
# Chin Hin Employee AI Assistant
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ================================================

# App Settings
ENVIRONMENT=development
DEBUG=true

# DEV_MODE=true  →  bypasses auth (use mock user automatically)
# DEV_MODE=false →  requires real JWT token from /auth/login
DEV_MODE=true

# ── Azure OpenAI (required for AI chat to work) ──
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Azure AI Foundry (optional) ──
AZURE_AI_PROJECT_CONNECTION_STRING=region.api.azureml.ms;subscription-id;resource-group;project-name

# ── Supabase (optional — not used in current in-memory mode) ──
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
